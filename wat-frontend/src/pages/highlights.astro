---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import VideoEmbed from '../components/VideoEmbed.astro';

const title = 'Video highlights';
const description =
	'Selected field hockey clips on YouTube — use the Open on YouTube link under each video to open the original.';

const videos = [
	{ id: 'p8OF9JyiBC0', label: 'Highlight 1' },
	{ id: 'Lv67PLvUuu8', label: 'Highlight 2' },
	{ id: 'kUjGPFgoHgs', label: 'Highlight 3' },
	{ id: 'nAD9Wn_EkpY', label: 'Highlight 4' },
] as const;
---

<BaseLayout title={title} description={description}>
	<PageHeader title={title} description={description} />
	<div class="video-grid">
		{videos.map(({ id, label }) => (
			<VideoEmbed videoId={id} title={label} />
		))}
	</div>
</BaseLayout>
