---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CitationNote from '../components/CitationNote.astro';

const entry = await getEntry('articles', 'rules');
if (!entry) throw new Error('Missing content: articles/rules');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<PageHeader title={entry.data.title} description={entry.data.description} />
	<CitationNote
		lastReviewed={entry.data.lastReviewed ?? '2026-03-27'}
		links={[
			{ href: 'https://www.usafieldhockey.com/rules-of-hockey', label: 'USA Field Hockey — Rules hub' },
			{ href: 'https://www.fih.hockey/rules-of-hockey', label: 'FIH Rules of Field Hockey' },
			{ href: 'https://www.usafieldhockey.com/umpires/resources', label: 'USA Field Hockey — Umpire resources' },
		]}
		secondaryLinks={[
			{
				href: 'https://www.ncaa.com/news/fieldhockey/article/2024-08-08/college-field-hockey-rules-explained',
				label: 'NCAA.com — college rules explained',
			},
		]}
	/>
	<article class="prose">
		<Content />
	</article>
</BaseLayout>
