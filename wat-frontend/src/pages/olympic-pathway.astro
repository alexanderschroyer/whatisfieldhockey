---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CitationNote from '../components/CitationNote.astro';

const entry = await getEntry('articles', 'olympic-pathway');
if (!entry) throw new Error('Missing content: articles/olympic-pathway');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<PageHeader title={entry.data.title} description={entry.data.description} />
	<CitationNote
		lastReviewed={entry.data.lastReviewed ?? '2026-03-27'}
		links={[
			{ href: 'https://www.usafieldhockey.com/', label: 'USA Field Hockey' },
			{ href: 'https://www.teamusa.com/', label: 'Team USA / USOPC' },
		]}
	/>
	<article class="prose">
		<Content />
	</article>
</BaseLayout>
