---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CitationNote from '../components/CitationNote.astro';
import Timeline from '../components/Timeline.astro';
import { historyEvents } from '../data/history';

const entry = await getEntry('articles', 'history-intro');
if (!entry) throw new Error('Missing content: articles/history-intro');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<PageHeader title={entry.data.title} description={entry.data.description} />
	<CitationNote
		lastReviewed={entry.data.lastReviewed ?? '2026-03-27'}
		links={[
			{ href: 'https://www.fih.hockey/', label: 'FIH' },
			{ href: 'https://www.usafieldhockey.com/', label: 'USA Field Hockey' },
			{ href: 'https://www.usafieldhockey.com/rules-of-hockey', label: 'USA Field Hockey — Rules hub' },
		]}
	/>
	<article class="prose">
		<Content />
	</article>
	<Timeline items={historyEvents} />
</BaseLayout>
