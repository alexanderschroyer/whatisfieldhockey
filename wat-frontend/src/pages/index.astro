---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMedia from '../components/HeroMedia.astro';
import ProgramTeaser from '../components/ProgramTeaser.astro';
import PartnerStrip from '../components/PartnerStrip.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { contactEmail } from '../config/site';

const mailto = `mailto:${contactEmail}`;
const homeDescription =
	'Youth field hockey in Alabama: free try-its and clinics first, then season signup — plus community, rules, history, and pathways.';
const featuredVideoId = 'p8OF9JyiBC0';
---

<BaseLayout title="Home" description={homeDescription}>
	<section class="hero-home" aria-labelledby="hero-heading">
		<HeroMedia
			imageSrc="/images/hero-home.png"
			imageAlt="Field hockey player in a USA uniform celebrating on a blue turf pitch after a big play."
		/>
		<div class="hero-home__content">
			<h1 id="hero-heading">Play field hockey in Alabama</h1>
			<p class="hero-home__tagline">
				Fun, friends, and fresh air — a welcoming sport for kids and a simple path for parents (schedule, fees,
				registration).
			</p>
			<p class="hero-home__kids-line">
				Grab a stick, run with friends, learn push-and-pass in small games — no experience required.
			</p>
			<div class="hero-home__actions">
				<a class="btn btn--primary" href="/events/">Try-it &amp; events</a>
				<a class="btn btn--ghost" href="/programs/">Programs &amp; how to join</a>
				<a class="btn btn--ghost" href={mailto}>Email us</a>
			</div>
			<p class="hero-home__path-hint">New to the sport? A free try-it is the easiest first step.</p>
		</div>
	</section>

	<section class="values-strip" aria-label="What we care about">
		<ul class="values-strip__list">
			<li><strong>Fun</strong> first</li>
			<li><strong>Community</strong> on and off the pitch</li>
			<li><strong>Convenient</strong> info for busy families</li>
			<li><strong>Cost-conscious</strong> programming</li>
		</ul>
	</section>

	<ProgramTeaser />

	<PhotoGallery />

	<section class="locations-section" aria-labelledby="locations-heading">
		<h2 id="locations-heading" class="section-heading">Field hockey in Alabama</h2>
		<p class="locations-section__lead">
			The sport is growing. Local teams, school clubs, and USA Field Hockey regions are part of the map — details on
			<a href="/about/">About</a>. Don’t see your area? <a href="/contact/">Help us expand</a>.
		</p>
	</section>

	<PartnerStrip />
	<TestimonialBlock />

	<section class="featured-video-section" aria-labelledby="featured-video-heading">
		<h2 id="featured-video-heading" class="section-heading">See the game</h2>
		<p class="featured-video-section__lead">Short highlights — more clips on <a href="/highlights/">Video highlights</a>.</p>
		<VideoEmbed videoId={featuredVideoId} title="Featured field hockey highlight" />
	</section>

	<section class="learn-section" aria-labelledby="learn-heading">
		<h2 id="learn-heading" class="section-heading">Learn the game</h2>
		<p class="learn-section__lead">
			Rules, history, scholarships, and pathways — deep dives for coaches, athletic directors (ADs), and curious families.
		</p>
		<div class="card-grid">
			<a class="card" href="/rules/">
				<h3>Rules</h3>
				<p>Circle, restarts, corners, and where to read FIH rules plus USA Field Hockey’s rules hub.</p>
			</a>
			<a class="card" href="/history/">
				<h3>History</h3>
				<p>Timeline from early organized play to the modern international game.</p>
			</a>
			<a class="card" href="/sport-today/">
				<h3>Sport today</h3>
				<p>World vs USA and how men’s and women’s pathways differ domestically.</p>
			</a>
			<a class="card" href="/scholarships/">
				<h3>Scholarships</h3>
				<p>NCAA levels, women’s varsity context, and compliance cautions.</p>
			</a>
			<a class="card" href="/highlights/">
				<h3>Video highlights</h3>
				<p>Embedded YouTube clips to see the game in action.</p>
			</a>
			<a class="card" href="/olympic-pathway/">
				<h3>Olympic pathway</h3>
				<p>Youth and junior teams through senior national programs — verify live details with USA Field Hockey.</p>
			</a>
		</div>
	</section>
</BaseLayout>
