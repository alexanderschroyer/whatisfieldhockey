---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CitationNote from '../components/CitationNote.astro';

const entry = await getEntry('articles', 'scholarships');
if (!entry) throw new Error('Missing content: articles/scholarships');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<PageHeader title={entry.data.title} description={entry.data.description} />
	<CitationNote
		lastReviewed={entry.data.lastReviewed ?? '2026-03-27'}
		links={[
			{ href: 'https://www.ncaa.org/sports/recruiting/', label: 'NCAA recruiting' },
			{ href: 'https://web3.ncaa.org/ecwr3/', label: 'NCAA Eligibility Center' },
			{ href: 'https://nfhca.org/', label: 'NFHCA' },
		]}
	/>
	<article class="prose">
		<Content />
	</article>
</BaseLayout>
