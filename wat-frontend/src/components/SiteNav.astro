---
const path = Astro.url.pathname;
const link = (href: string, label: string) => ({ href, label, current: path === href || (href !== '/' && path.startsWith(href)) });

const items = [
	link('/', 'Home'),
	link('/rules/', 'Rules'),
	link('/history/', 'History'),
	link('/sport-today/', 'Sport today'),
	link('/scholarships/', 'Scholarships'),
	link('/highlights/', 'Highlights'),
	link('/olympic-pathway/', 'Olympic pathway'),
];
---

<nav class="site-nav" aria-label="Primary">
	{
		items.map(({ href, label, current }) => (
			<a href={href} aria-current={current ? 'page' : undefined}>
				{label}
			</a>
		))
	}
</nav>
